# Dev: use Vite proxy (/api -> localhost:5000). Production: set full URL in Vercel.
VITE_API_BASE_URL=/api/v1

# Payment mode hint for UI (mock | sandbox | production). Must match server BKASH_MODE.
VITE_BKASH_MODE=sandbox

# Google reCAPTCHA site key (leave blank to disable the widget in dev)
VITE_RECAPTCHA_SITE_KEY=

# Google Maps embed: a public API key OR a plain query string fallback is used.
VITE_GOOGLE_MAPS_EMBED_KEY=
